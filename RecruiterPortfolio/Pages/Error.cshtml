@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center" style="margin-top:80px; max-width:800px;">
    <h1 class="display-3" style="color:#e74c3c; font-weight:bold;">
        Oops! Something went wrong 😟
    </h1>
    <p class="lead" style="color:#2c3e50; margin-top:20px;">
        An unexpected error occurred while processing your request. Please try again later.
    </p>

    @if (Model.ShowRequestId)
    {
        <p style="margin-top:20px; color:#7f8c8d;">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <hr style="width:60%; margin:40px auto; border-top:2px solid #3498db;" />

    <h3 style="color:#3498db;">What you can do:</h3>
    <ul class="list-unstyled" style="font-size:18px; color:#2c3e50; margin-top:20px;">
        <li>✔️ Refresh the page</li>
        <li>✔️ Return to the <a href="/" style="color:#e74c3c; font-weight:bold;">Home page</a></li>
        <li>✔️ Contact me if the issue persists</li>
    </ul>

    <hr style="width:60%; margin:40px auto; border-top:2px solid #3498db;" />

    <p style="color:#7f8c8d; font-size:14px;">
        ⚠️ For developers: Enable the <strong>Development</strong> environment locally to see detailed error information. 
        Do not enable Development mode in production.
    </p>

    <p class="text-center" style="color:#7f8c8d; font-size:14px; margin-top:30px;">
        © 2026 - RecruiterPortfolio. All rights reserved.
    </p>
</div>
